# Optional: max session-channel auto-deposit (human USDC units, 6 decimals). Default 50.
# VITE_X402_SESSION_MAX_DEPOSIT=50

OPENAI_API_KEY=
# Hub explainer + optional Bearer for OpenAI proxy. Wallet-only: leave empty and use /openai with wallet x402.
OPENAI_MODEL=gpt-4o-mini
# OpenAI-compatible gateway (chat completions) — wallet-paid x402 upstream.
OPENAI_X402_GATEWAY_URL=https://openai.mpp.tempo.xyz
# Anthropic (Claude) — see /anthropic. Optional key skips wallet.
ANTHROPIC_API_KEY=
ANTHROPIC_X402_GATEWAY_URL=https://anthropic.mpp.tempo.xyz
# Optional; default matches Anthropic Messages API.
# ANTHROPIC_API_VERSION=2023-06-01
# OpenRouter — see /openrouter.
OPENROUTER_API_KEY=
OPENROUTER_X402_GATEWAY_URL=https://openrouter.mpp.tempo.xyz
# Perplexity — see /perplexity.
PERPLEXITY_API_KEY=
PERPLEXITY_X402_GATEWAY_URL=https://perplexity.mpp.tempo.xyz
# Alchemy — see /alchemy.
ALCHEMY_API_KEY=
ALCHEMY_X402_GATEWAY_URL=https://mpp.alchemy.com
# fal.ai — see /fal.
FAL_API_KEY=
FAL_X402_GATEWAY_URL=https://fal.mpp.tempo.xyz
# Replicate — see /replicate.
REPLICATE_API_KEY=
REPLICATE_X402_GATEWAY_URL=https://replicate.mpp.paywithlocus.com
# Parallel (search / extract / task). Wallet-paid via app proxy; see /parallel
PARALLEL_BASE_URL=https://parallelmpp.dev
PARALLEL_API_KEY=
# Optional Bearer for direct AgentMail API calls (see server routes).
AGENTMAIL_API_KEY=your_agentmail_api_key_here
# Direct REST API (v0 inboxes, messages, …)
AGENTMAIL_BASE_URL=https://api.agentmail.to
# Wallet-paid gateway for AgentMail (default below).
AGENTMAIL_WALLET_GATEWAY_URL=https://mpp.api.agentmail.to
# Fallback if the client omits `inbox_id` (the /dance-extras bot flow sends `streetkode@agentmail.to` by default).
AGENTMAIL_INBOX_ID=your_agentmail_inbox_id_here
# Legacy (no longer used by the server): AgentMail send is now
# POST /v0/inboxes/{inbox_id}/messages/send
AGENTMAIL_SEND_PATH=/v1/send
AVIATIONSTACK_API_KEY=your_aviationstack_api_key_here
AVIATIONSTACK_BASE_URL=http://api.aviationstack.com/v1
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_MAPS_BASE_URL=https://maps.googleapis.com/maps/api
KICKSDB_API_KEY=your_kicksdb_api_key_here
KICKSDB_BASE_URL=https://kicksdb.mpp.tempo.xyz
KICKSDB_SEARCH_PATH=/v3/stockx/products
# Optional: OpenWeather `appid` for direct queries. If unset, use /weather + wallet x402 on mainnet.
OPENWEATHER_API_KEY=
OPENWEATHER_BASE_URL=https://weather.mpp.paywithlocus.com
# Gateway uses POST JSON. Not legacy GET /data/2.5/weather.
OPENWEATHER_CURRENT_PATH=/openweather/current-weather
# Suno host (optional overrides).
SUNO_BASE_URL=https://suno.mpp.paywithlocus.com
SUNO_GENERATE_PATH=/suno/generate-music
# Optional legacy header auth; StablePhone primarily uses x402 + SIWX flows.
STABLEPHONE_API_KEY=
STABLEPHONE_BASE_URL=https://stablephone.dev
STABLEPHONE_CALL_PATH=/api/call
STABLEPHONE_STATUS_PATH=/api/call
STABLESOCIAL_BASE_URL=https://stablesocial.dev
STABLESOCIAL_INSTAGRAM_PROFILE_PATH=/api/instagram/profile
STABLESOCIAL_JOBS_PATH=/api/jobs
CARD_PROVIDER=laso
LASO_BASE_URL=https://laso.mpp.paywithlocus.com
LASO_CARD_PATH=/get-card
LASO_CARD_STATUS_PATH=/get-card-data
PORT=8787

# NHS API: x402 payment gate on gated writes (GP access, care plans, …). Default on.
# Set to false only for local smoke tests without a wallet payment.
# NHS_ENABLE_PAYMENT_GATE=true

# Arc Testnet (chain id 5042002) — see docs/ARC_X402_NOTES.md
ARC_TESTNET=true

# Payment scaffold (used when PAYMENT_MODE=mock or live)
PAYMENT_MODE=mock
X402_CURRENCY=
# Seller/recipient address for x402 settlement (Arc Testnet USDC).
X402_SELLER_ADDRESS=0x742d35Cc6634c0532925a3b844bC9e7595F8fE00
X402_DECIMALS=6
