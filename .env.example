# Clinical Arc (NHS core) — concise env template
# Copy to .env and fill only what you use.

# Core server
PORT=8787
ARC_TESTNET=true

# x402 payments (Arc Testnet)
# Seller/recipient wallet for payment settlement.
X402_SELLER_ADDRESS=0x742d35Cc6634c0532925a3b844bC9e7595F8fE00
# Optional overrides (usually leave as-is)
X402_DECIMALS=6
# X402_CURRENCY=
# PAYMENT_MODE=mock
# NHS_ENABLE_PAYMENT_GATE=true

# Optional: browser session deposit cap (human units)
# VITE_X402_SESSION_MAX_DEPOSIT=50

# Optional: OpenAI proxy (if you use /api/openai/*)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_X402_GATEWAY_URL=https://openai.mpp.tempo.xyz

# Optional: AgentMail (only if you use AgentMail routes)
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX_ID=
AGENTMAIL_BASE_URL=https://api.agentmail.to
AGENTMAIL_WALLET_GATEWAY_URL=https://mpp.api.agentmail.to

# Notes:
# - Circle Faucet for Arc Testnet: https://faucet.circle.com/
# - No Circle API key is required for the public faucet flow.
